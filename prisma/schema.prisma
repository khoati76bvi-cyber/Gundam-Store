generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  name        String
  category    String
  grade       String?
  price       Int
  compareAt   Int?
  stock       Int      @default(0)
  image       String
  gallery     String   @default("[]")
  badge       String?
  status      String   @default("ACTIVE")
  description String
  specs       String   @default("{}")
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orderItems  OrderItem[]
}

model Banner {
  id           Int       @id @default(autoincrement())
  title        String
  subtitle     String    @default("")
  image        String    @default("")
  ctaText      String    @default("Xem ngay")
  ctaHref      String    @default("/")
  mediaType    String    @default("image") // image | video | gif | webp
  desktopMedia String    @default("")
  mobileMedia  String    @default("")
  linkUrl      String    @default("/")
  buttonText   String    @default("Xem ngay")
  position     String    @default("HOME_HERO")
  openNewTab   Boolean   @default(false)
  autoplayMs   Int       @default(4500)
  sortOrder    Int       @default(0)
  active       Boolean   @default(true)
  startsAt     DateTime?
  endsAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  phone     String?
  address   String?
  tier      String   @default("Member")
  createdAt DateTime @default(now())
  orders    Order[]
}

model Order {
  id            Int           @id @default(autoincrement())
  code          String        @unique
  customerId    Int?
  customer      Customer?     @relation(fields: [customerId], references: [id])
  customerName  String
  customerEmail String
  phone         String
  address       String
  note          String?
  status String @default("NEW")
  paymentMethod String        @default("COD")
  paymentStatus String @default("PENDING")
  subtotal      Int
  discount      Int           @default(0)
  shippingFee   Int           @default(30000)
  total         Int
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  items         OrderItem[]
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  name      String
  price     Int
  quantity  Int
}

model Coupon {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  type      String   @default("PERCENT")
  value     Int
  active    Boolean  @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime @default(now())
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}


model MediaAsset {
  id        Int      @id @default(autoincrement())
  url       String
  filename  String
  mimeType  String
  size      Int
  alt       String?
  folder    String   @default("products")
  createdAt DateTime @default(now())
}

model ContentPage {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  title       String
  type        String   @default("BLOG")
  excerpt     String?
  coverImage  String?
  body        String
  status      String   @default("DRAFT")
  seoTitle    String?
  seoDesc     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InventoryLog {
  id        Int      @id @default(autoincrement())
  productId Int
  productName String
  type      String
  quantity  Int
  note      String?
  createdAt DateTime @default(now())
}

model AnalyticsEvent {
  id         Int      @id @default(autoincrement())
  sessionId  String
  userId     String?
  type       String
  path       String?
  productId  Int?
  productSlug String?
  productName String?
  bannerId   Int?
  keyword    String?
  value      Int?
  metadata   String   @default("{}")
  createdAt  DateTime @default(now())

  @@index([type])
  @@index([sessionId])
  @@index([createdAt])
  @@index([productSlug])
  @@index([keyword])
}

model SearchInsight {
  id          Int      @id @default(autoincrement())
  keyword     String
  resultCount Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([keyword])
  @@index([createdAt])
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  name      String
  role String @default("EDITOR")
  active    Boolean   @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}